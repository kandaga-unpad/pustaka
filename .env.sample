# Sample environment variables for Podman / local development
# Copy this file to `.env` and customize values before running podman-compose.

# Postgres settings
POSTGRES_USER=voile
POSTGRES_PASSWORD=change_me
POSTGRES_DB=voile_dev

# App and Phoenix settings
MIX_ENV=dev
PORT=4000

# Ecto expects a DATABASE_URL in the form: ecto://USER:PASS@HOST/DATABASE
# If you leave DATABASE_URL empty the compose will compose one from the above values.
DATABASE_URL=

# Generate this with: mix phx.gen.secret
# For dev you may set any long random string. For production use a secure value.
SECRET_KEY_BASE=replace_me_with_generated_secret
