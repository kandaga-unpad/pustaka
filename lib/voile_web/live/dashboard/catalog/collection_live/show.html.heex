<section class="flex flex-col gap-4">
  <div class="bg-white dark:bg-gray-700 py-3 sm:py-4 px-4 sm:px-6 lg:px-8 rounded-xl shadow-md">
    <.back navigate={~p"/manage/catalog/collections?#{@back_query_params}"}>
      Back to collections
    </.back>

    <.header>
      <span class="text-sm sm:text-base">
        Collection :
        <span class="text-orange-600 font-bold break-words">{@collection.title}</span>
      </span>
      <:subtitle>
        <span class="text-xs sm:text-sm">Collection ID : {@collection.id}</span>
      </:subtitle>

      <:actions>
        <.link
          patch={~p"/manage/catalog/collections/#{@collection}/show/edit"}
          phx-click={JS.push_focus()}
          class="w-full sm:w-auto"
        >
          <.button class="primary-btn">
            <.icon name="hero-pencil" class="w-4 h-4" /> Edit collection
          </.button>
        </.link>
      </:actions>
    </.header>

    <div class="flex flex-col lg:flex-row gap-4 sm:gap-6 w-full">
      <div class="flex items-start justify-center w-full lg:w-96 flex-shrink-0">
        <%= if @collection.thumbnail do %>
          <img
            src={@collection.thumbnail}
            class="object-cover w-full h-full rounded-lg border border-gray-200 dark:border-gray-600"
            alt={@collection.title}
          />
        <% else %>
          <div class="w-full h-64 sm:h-80 lg:h-96 flex items-center justify-center border rounded-lg border-voile-primary dark:border-gray-200 bg-gray-50 dark:bg-gray-800">
            <p class="text-sm text-gray-500">No thumbnail available</p>
          </div>
        <% end %>
      </div>

      <.list>
        <:item title="Title">{@collection.title || "-"}</:item>

        <:item title="Creator">
          {(@collection.mst_creator && @collection.mst_creator.creator_name) || "No creator"}
        </:item>

        <:item title="Description">{@collection.description || "-"}</:item>

        <:item title="Status">{@collection.status || "-"}</:item>

        <:item title="Thumbnail">
          <%= if @collection.thumbnail do %>
            <.link
              navigate={@collection.thumbnail}
              target="_blank"
              class="text-voile-primary hover:underline"
            >
              View
            </.link>
          <% else %>
            -
          <% end %>
        </:item>

        <:item title="Access Level">{@collection.access_level || "-"}</:item>

        <:item title="Custodian">
          <div class="text-xs text-gray-400 italic">
            <div>
              Created by:
              <%= if @collection.created_by != nil do %>
                {@collection.created_by.fullname} on ({to_local_time(@collection.inserted_at)})
              <% else %>
                -
              <% end %>
            </div>
            <div>
              Updated by:
              <%= if @collection.updated_by != nil do %>
                {@collection.updated_by.fullname} on ({to_local_time(@collection.updated_at)})
              <% else %>
                -
              <% end %>
            </div>
          </div>
        </:item>
      </.list>
    </div>

    <%!-- Parent and Children Collections Section --%>
    <%= if @collection.parent || length(@collection.children) > 0 do %>
      <div class="my-10">
        <h6 class="text-lg sm:text-xl font-semibold text-gray-800 dark:text-white my-4 sm:my-5">
          Collection Relationships
        </h6>

        <div class="bg-gray-50 dark:bg-gray-800 rounded-lg p-4 sm:p-6 space-y-6">
          <%!-- Parent Collection --%>
          <%= if @collection.parent do %>
            <div>
              <h3 class="text-sm font-semibold text-gray-700 dark:text-gray-300 mb-3 flex items-center gap-2">
                <.icon name="hero-arrow-up-circle" class="w-5 h-5 text-blue-500" />
                Parent Collection
              </h3>
              <div class="bg-white dark:bg-gray-700 rounded-lg p-4 shadow-sm">
                <div class="flex flex-col sm:flex-row items-start gap-4">
                  <%!-- A4-sized cover (210mm x 297mm ratio = ~1:1.414) --%>
                  <%= if @collection.parent.thumbnail do %>
                    <img
                      src={@collection.parent.thumbnail}
                      alt={@collection.parent.title}
                      class="w-full sm:w-48 h-64 sm:h-68 object-cover rounded-lg border border-gray-200 dark:border-gray-600 flex-shrink-0"
                    />
                  <% else %>
                    <div class="w-full sm:w-48 h-64 sm:h-68 flex items-center justify-center border rounded-lg border-gray-300 dark:border-gray-500 bg-gray-100 dark:bg-gray-600 flex-shrink-0">
                      <.icon name="hero-folder" class="w-16 h-16 text-gray-400" />
                    </div>
                  <% end %>

                  <div class="flex-1 min-w-0 flex flex-col justify-between">
                    <div>
                      <h4 class="font-semibold text-gray-900 dark:text-white text-base sm:text-lg">
                        {@collection.parent.title}
                      </h4>
                      <%= if @collection.parent.description do %>
                        <p class="text-sm text-gray-600 dark:text-gray-400 mt-2 line-clamp-3">
                          {@collection.parent.description}
                        </p>
                      <% end %>
                      <div class="flex items-center gap-2 mt-3">
                        <span class="text-xs px-2 py-1 rounded-full bg-blue-100 text-blue-800 dark:bg-blue-900 dark:text-blue-200">
                          {String.capitalize(@collection.parent.status || "draft")}
                        </span>
                        <span class="text-xs text-gray-500 dark:text-gray-400">
                          ID: {String.slice(@collection.parent.id, 0..7)}...
                        </span>
                      </div>
                    </div>

                    <div class="mt-4">
                      <.link
                        navigate={~p"/manage/catalog/collections/#{@collection.parent.id}"}
                        class="inline-block w-full sm:w-auto"
                      >
                        <.button class="primary-btn w-full">
                          <.icon name="hero-arrow-right-circle" class="w-4 h-4" />
                          View Parent Collection
                        </.button>
                      </.link>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          <% end %>

          <%!-- Children Collections --%>
          <%= if length(@collection.children) > 0 do %>
            <div>
              <h3 class="text-sm font-semibold text-gray-700 dark:text-gray-300 mb-3 flex items-center gap-2">
                <.icon name="hero-arrow-down-circle" class="w-5 h-5 text-green-500" />
                Child Collections ({length(@collection.children)})
              </h3>
              <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
                <%= for child <- @collection.children do %>
                  <div class="bg-white dark:bg-gray-700 rounded-lg p-4 shadow-sm hover:shadow-md transition flex flex-col">
                    <%!-- A4-sized cover --%>
                    <%= if child.thumbnail do %>
                      <img
                        src={child.thumbnail}
                        alt={child.title}
                        class="w-full h-80 object-cover rounded-lg border border-gray-200 dark:border-gray-600"
                      />
                    <% else %>
                      <div class="w-full h-80 flex items-center justify-center border rounded-lg border-gray-300 dark:border-gray-500 bg-gray-100 dark:bg-gray-600">
                        <.icon name="hero-folder" class="w-16 h-16 text-gray-400" />
                      </div>
                    <% end %>

                    <div class="flex-1 flex flex-col mt-3">
                      <div class="flex-1">
                        <h4 class="font-semibold text-gray-900 dark:text-white text-sm line-clamp-2">
                          {child.title}
                        </h4>
                        <%= if child.description do %>
                          <p class="text-xs text-gray-600 dark:text-gray-400 mt-2 line-clamp-2">
                            {child.description}
                          </p>
                        <% end %>
                        <div class="flex items-center gap-2 mt-2">
                          <span class="text-xs px-2 py-1 rounded-full bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200">
                            {String.capitalize(child.status || "draft")}
                          </span>
                        </div>
                      </div>

                      <div class="mt-4">
                        <.link
                          navigate={~p"/manage/catalog/collections/#{child.id}"}
                          class="block"
                        >
                          <.button class="primary-btn w-full text-xs sm:text-sm">
                            <.icon name="hero-arrow-right-circle" class="w-4 h-4" />
                            View Collection
                          </.button>
                        </.link>
                      </div>
                    </div>
                  </div>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>

    <div class="my-10">
      <h6 class="my-5">Metadata</h6>

      <div>
        <div class="overflow-x-auto">
          <table class="min-w-full divide-y divide-gray-200 border border-gray-200 rounded-lg">
            <thead class="bg-gray-50 dark:bg-gray-800">
              <tr>
                <th class="p-4 text-left text-xs font-medium uppercase tracking-wider border-b border-gray-200">
                  Field
                </th>

                <th class="p-4 text-left text-xs font-medium uppercase tracking-wider border-b border-gray-200">
                  Value
                </th>
              </tr>
            </thead>

            <tbody class="bg-white dark:bg-gray-800 divide-y divide-gray-200">
              <%= for field <- @collection.collection_fields do %>
                <tr class="hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors">
                  <td class="p-4 text-sm font-medium border-r border-gray-200 w-1/3">
                    {field.label}
                  </td>

                  <td class="p-4 text-sm">{field.value}</td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <div>
      <h6 class="text-lg sm:text-xl font-semibold text-gray-800 dark:text-white my-4 sm:my-5">
        Items ({length(@collection.items)})
      </h6>

      <%= if length(@collection.items) > 0 do %>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-6">
          <%= for item <- @collection.items do %>
            <div class="item-card bg-white dark:bg-gray-600 rounded-lg sm:rounded-xl shadow-sm overflow-hidden relative fade-in">
              <!-- Availability Badge -->
              <div class="absolute top-2 sm:top-3 right-2 sm:right-3 z-10">
                {availability_badge(item.availability)}
              </div>

              <div class="p-3 sm:p-5">
                <div class="flex justify-between items-start mt-6 mb-3 sm:mb-4">
                  <h3 class="font-semibold text-gray-800 dark:text-white text-sm sm:text-lg">
                    Item: <br />
                    <span class="font-medium italic break-all">{item.item_code}</span>
                  </h3>
                </div>

                <div class="flex flex-col gap-2 sm:gap-3 text-xs">
                  <div class="grid grid-cols-3">
                    <p>Inventory Code</p>

                    <p class="col-span-2">: {item.inventory_code}</p>
                  </div>

                  <div class="grid grid-cols-3">
                    <p>Location</p>

                    <p class="col-span-2">: {item.location}</p>
                  </div>

                  <div class="grid grid-cols-3">
                    <p>Condition</p>

                    <p class="col-span-2">: {condition_badge(item.condition)}</p>
                  </div>

                  <div class="grid grid-cols-3">
                    <p>Status</p>

                    <p class="col-span-2">: {status_badge(item.status)}</p>
                  </div>

                  <%= if item.node do %>
                    <div class="grid grid-cols-3">
                      <p>Node</p>

                      <p class="col-span-2">: {item.node.name}</p>
                    </div>
                  <% end %>
                </div>

                <div class="mt-4 sm:mt-6 text-xs sm:text-sm text-center pt-3 sm:pt-4 border-t border-gray-100 flex flex-col sm:flex-row items-center gap-2 w-full">
                  <.link
                    navigate={"/manage/catalog/items/#{item.id}"}
                    class="primary-btn font-medium w-full py-2.5 sm:py-2 touch-manipulation text-[10px]"
                  >
                    Item Detail
                  </.link>
                  <button
                    phx-click="request_transfer"
                    phx-value-item-id={item.id}
                    class="warning-btn rounded-lg w-full py-2.5 sm:py-2 touch-manipulation text-[10px]"
                  >
                    Transfer Location
                  </button>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="text-gray-500">No items found.</p>
      <% end %>
    </div>

    <div>
      <h6 class="text-lg sm:text-xl font-semibold text-gray-800 dark:text-white my-4 sm:my-5">
        Attachments
      </h6>

      <%= if length(@collection.attachments) > 0 do %>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3 sm:gap-4">
          <%= for attachment <- @collection.attachments do %>
            <div class="flex flex-col justify-between p-3 sm:p-4 rounded-lg border border-gray-200 bg-white dark:bg-gray-600 shadow-sm hover:shadow-md hover:bg-gray-50 dark:hover:bg-gray-700 active:bg-gray-100 dark:active:bg-gray-600 transition touch-manipulation">
              <!-- Top: Icon or Preview -->
              <div class="flex items-center justify-center h-24 sm:h-32 mb-2 sm:mb-3 bg-gray-50 dark:bg-gray-800 rounded-lg overflow-hidden">
                <%= if attachment.file_type == "image" do %>
                  <!-- Image Preview -->
                  <img
                    src={Catalog.get_file_url(attachment)}
                    alt={attachment.original_name}
                    class="object-cover w-full h-full"
                  />
                <% else %>
                  {file_type_icon(attachment.file_type)}
                <% end %>
              </div>

              <div class="flex-1">
                <div class="flex items-center justify-between">
                  <p
                    class="font-medium text-gray-800 dark:text-gray-200 truncate max-w-[70%]"
                    title={attachment.original_name}
                  >
                    {attachment.original_name}
                  </p>

                  <span class={"ml-2 px-2 py-0.5 text-xs rounded-full #{badge_color(attachment.file_type)}"}>
                    {String.capitalize(attachment.file_type)}
                  </span>
                </div>

                <p class="text-sm text-gray-500 dark:text-gray-300">
                  {format_bytes(attachment.file_size)}
                </p>
              </div>

              <div class="mt-2 sm:mt-3">
                <a
                  href={Catalog.get_file_url(attachment)}
                  download={attachment.original_name}
                  class="w-full inline-block text-center px-3 py-2.5 sm:py-2 bg-indigo-600 text-white text-xs sm:text-sm rounded-lg shadow hover:bg-indigo-700 active:bg-indigo-800 transition touch-manipulation"
                >
                  Download
                </a>
              </div>
            </div>
          <% end %>
        </div>

        <div class="my-4 sm:my-6">
          <.link
            navigate={~p"/manage/catalog/collections/#{@collection}/attachments"}
            class="w-full inline-block text-center px-4 py-3 sm:py-2 bg-indigo-600 text-white text-sm rounded-lg shadow hover:bg-indigo-700 active:bg-indigo-800 transition touch-manipulation"
          >
            Manage Attachments
          </.link>
        </div>
      <% else %>
        <p class="text-sm text-gray-500">No attachments found.</p>

        <div class="my-4 sm:my-6">
          <.link
            navigate={~p"/manage/catalog/collections/#{@collection}/attachments"}
            class="w-full inline-block text-center px-4 py-3 sm:py-2 bg-indigo-600 text-white text-sm rounded-lg shadow hover:bg-indigo-700 active:bg-indigo-800 transition touch-manipulation"
          >
            Add an Attachment
          </.link>
        </div>
      <% end %>
    </div>

    <.back navigate={~p"/manage/catalog/collections?#{@back_query_params}"}>
      Back to collections
    </.back>

    <.collection_modal
      :if={@live_action == :edit}
      id="collection-modal"
      show
      on_cancel={JS.patch(~p"/manage/catalog/collections/#{@collection}")}
    >
      <.live_component
        module={VoileWeb.Dashboard.Catalog.CollectionLive.FormComponent}
        id={@collection.id}
        title={@page_title}
        action={@live_action}
        collection={@collection}
        show_add_collection_field={@show_add_collection_field}
        step={@step}
        creator_list={@creator}
        collection_type={@collection_type}
        collection_properties={@collection_properties}
        resource_templates={@resource_templates}
        node_list={@node_location}
        current_scope={@current_scope}
        time_identifier={@time_identifier}
        patch={~p"/manage/catalog/collections/#{@collection}"}
      />
    </.collection_modal>
    <%!-- Transfer Request Modal --%>
    <.modal
      :if={@live_action == :request_transfer && @transfer_item}
      id="transfer-modal"
      show
      on_cancel={JS.push("cancel_transfer")}
    >
      <.live_component
        module={VoileWeb.Dashboard.Catalog.TransferRequestLive.FormComponent}
        id={:new}
        title="Request Transfer Location"
        action={:new}
        item={@transfer_item}
        current_scope={@current_scope}
        patch={~p"/manage/catalog/collections/#{@collection}"}
      />
    </.modal>
    <%!-- confirm-close removed: closing will navigate back to index directly --%>
  </div>
</section>
