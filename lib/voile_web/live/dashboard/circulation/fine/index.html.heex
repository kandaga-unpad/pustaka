<div class="px-4 py-6">
  <div class="sm:flex sm:items-center sm:justify-between mb-6">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">Library Fines</h1>
      
      <p class="mt-2 text-sm text-gray-700">Manage fines, payments, and waivers</p>
    </div>
    
    <div class="mt-4 sm:mt-0 sm:flex sm:space-x-3">
      <.link
        navigate={~p"/manage/circulation/fines/new"}
        class="inline-flex items-center px-4 py-2 bg-red-600 hover:bg-red-700 text-white text-sm font-medium rounded-md"
      >
        <.icon name="hero-plus" class="w-4 h-4 mr-2" /> New Fine
      </.link>
    </div>
  </div>
  <!-- Filters -->
  <div class="bg-white shadow rounded-lg mb-6">
    <div class="px-6 py-4 border-b border-gray-200">
      <form phx-change="filter">
        <div class="sm:flex sm:items-center sm:space-x-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Status</label>
            <select
              name="status"
              class="block w-40 text-sm border-gray-300 rounded-md shadow-sm focus:ring-red-500 focus:border-red-500"
            >
              <option value="all" selected={@filter_status == "all"}>All Status</option>
              
              <option value="pending" selected={@filter_status == "pending"}>Pending</option>
              
              <option value="partial_paid" selected={@filter_status == "partial_paid"}>
                Partial Paid
              </option>
              
              <option value="paid" selected={@filter_status == "paid"}>Paid</option>
              
              <option value="waived" selected={@filter_status == "waived"}>Waived</option>
            </select>
          </div>
          
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Type</label>
            <select
              name="type"
              class="block w-40 text-sm border-gray-300 rounded-md shadow-sm focus:ring-red-500 focus:border-red-500"
            >
              <option value="all" selected={@filter_type == "all"}>All Types</option>
              
              <option value="overdue" selected={@filter_type == "overdue"}>Overdue</option>
              
              <option value="lost_item" selected={@filter_type == "lost_item"}>Lost Item</option>
              
              <option value="damaged_item" selected={@filter_type == "damaged_item"}>
                Damaged Item
              </option>
              
              <option value="processing" selected={@filter_type == "processing"}>
                Processing
              </option>
            </select>
          </div>
        </div>
      </form>
    </div>
    <!-- Quick Stats -->
    <div class="px-6 py-4 bg-gray-50 grid grid-cols-1 sm:grid-cols-4 gap-4">
      <div class="text-center">
        <div class="text-2xl font-semibold text-red-600">-</div>
        
        <div class="text-xs text-gray-500 uppercase">Outstanding</div>
      </div>
      
      <div class="text-center">
        <div class="text-2xl font-semibold text-yellow-600">-</div>
        
        <div class="text-xs text-gray-500 uppercase">Partial Paid</div>
      </div>
      
      <div class="text-center">
        <div class="text-2xl font-semibold text-green-600">-</div>
        
        <div class="text-xs text-gray-500 uppercase">Paid Today</div>
      </div>
      
      <div class="text-center">
        <div class="text-2xl font-semibold text-blue-600">Rp -</div>
        
        <div class="text-xs text-gray-500 uppercase">Total Outstanding</div>
      </div>
    </div>
  </div>
  <!-- Fines Table -->
  <div class="bg-white shadow overflow-hidden sm:rounded-md">
    <.table id="fines" rows={@streams.fines}>
      <:col :let={{_id, fine}} label="Member">
        <div class="flex items-center">
          <div class="flex-shrink-0 h-10 w-10">
            <div class="h-10 w-10 rounded-full bg-gray-200 flex items-center justify-center">
              <span class="text-sm font-medium text-gray-700">
                {if fine.member, do: String.first(fine.member.full_name || "?"), else: "?"}
              </span>
            </div>
          </div>
          
          <div class="ml-4">
            <div class="text-sm font-medium text-gray-900">
              {if fine.member, do: fine.member.full_name, else: "Unknown Member"}
            </div>
            
            <div class="text-sm text-gray-500">ID: {fine.member_id}</div>
          </div>
        </div>
      </:col>
      
      <:col :let={{_id, fine}} label="Item">
        <div>
          <%= if fine.item do %>
            <div class="text-sm font-medium text-gray-900">{fine.item.item_code}</div>
            
            <div class="text-sm text-gray-500">
              {if fine.item.collection, do: fine.item.collection.title, else: "No collection"}
            </div>
          <% else %>
            <div class="text-sm text-gray-500">-</div>
          <% end %>
        </div>
      </:col>
      
      <:col :let={{_id, fine}} label="Fine Type">
        <span class={"inline-flex px-2 py-1 text-xs font-semibold rounded-full #{fine_type_badge_class(fine.fine_type)}"}>
          {fine.fine_type |> String.replace("_", " ") |> String.capitalize()}
        </span>
      </:col>
      
      <:col :let={{_id, fine}} label="Amount">
        <div class="text-sm font-medium text-gray-900">{format_idr(fine.amount)}</div>
      </:col>
      
      <:col :let={{_id, fine}} label="Paid">
        <div class="text-sm text-gray-900">{format_idr(fine.paid_amount)}</div>
      </:col>
      
      <:col :let={{_id, fine}} label="Balance">
        <div class={"text-sm font-medium #{if Decimal.equal?(fine.balance || Decimal.new(0), 0), do: "text-green-600", else: "text-red-600"}"}>
          {format_idr(fine.balance)}
        </div>
      </:col>
      
      <:col :let={{_id, fine}} label="Status">
        <span class={"inline-flex px-2 py-1 text-xs font-semibold rounded-full #{fine_status_badge_class(fine.fine_status)}"}>
          {if fine.waived do
            "Waived"
          else
            String.capitalize(fine.fine_status)
          end}
        </span>
      </:col>
      
      <:col :let={{_id, fine}} label="Fine Date">
        <div class="text-sm text-gray-900">{format_date(fine.fine_date)}</div>
      </:col>
      
      <:col :let={{_id, fine}} label="Payment Method">
        <div class="text-sm text-gray-900">
          {if fine.payment_method do
            String.capitalize(fine.payment_method)
          else
            "-"
          end}
        </div>
      </:col>
      
      <:action :let={{_id, fine}}>
        <div class="flex space-x-2">
          <%= if fine.fine_status in ["pending", "partial_paid"] && !fine.waived do %>
            <.link
              navigate={~p"/manage/circulation/fines/#{fine.id}/payment"}
              class="text-green-600 hover:text-green-900 text-sm font-medium"
            >
              Pay
            </.link>
            <.link
              navigate={~p"/manage/circulation/fines/#{fine.id}/waive"}
              class="text-blue-600 hover:text-blue-900 text-sm font-medium"
            >
              Waive
            </.link>
          <% end %>
          
          <.link
            navigate={~p"/manage/circulation/fines/#{fine.id}"}
            class="text-indigo-600 hover:text-indigo-900 text-sm font-medium"
          >
            View
          </.link>
        </div>
      </:action>
    </.table>
    <!-- Pagination -->
    <div class="bg-white px-4 py-3 border-t border-gray-200 sm:px-6">
      <.pagination page={@page} total_pages={@total_pages} />
    </div>
  </div>
</div>
<!-- Payment Modal -->
<.modal
  :if={@live_action == :payment}
  id="payment-modal"
  show
  on_cancel={JS.patch(~p"/manage/circulation/fines")}
>
  <div class="space-y-4">
    <h3 class="text-lg font-medium text-gray-900">Process Payment</h3>
    
    <div class="bg-gray-50 rounded-md p-4">
      <div class="grid grid-cols-2 gap-4 text-sm">
        <div>
          <span class="font-medium text-gray-700">Member:</span>
          <span class="ml-2">{if @fine.member, do: @fine.member.full_name, else: "Unknown"}</span>
        </div>
        
        <div>
          <span class="font-medium text-gray-700">Fine Type:</span>
          <span class="ml-2">
            {@fine.fine_type |> String.replace("_", " ") |> String.capitalize()}
          </span>
        </div>
        
        <div>
          <span class="font-medium text-gray-700">Total Amount:</span>
          <span class="ml-2">{format_idr(@fine.amount)}</span>
        </div>
        
        <div>
          <span class="font-medium text-gray-700">Outstanding:</span>
          <span class="ml-2 font-semibold text-red-600">{format_idr(@fine.balance)}</span>
        </div>
      </div>
    </div>
    
    <.form for={%{}} id="payment-form" phx-submit="process_payment" phx-value-id={@fine.id}>
      <.input
        name="amount"
        type="number"
        step="1"
        label="Payment Amount (Rp)"
        placeholder="0"
        value={(@fine.balance || Decimal.new(0)) |> Decimal.to_float() |> trunc()}
        required
      />
      <.input
        name="method"
        type="select"
        label="Payment Method"
        options={[
          {"Cash", "cash"},
          {"Credit Card", "credit_card"},
          {"Debit Card", "debit_card"},
          {"Bank Transfer", "bank_transfer"},
          {"Online Payment", "online"}
        ]}
        required
      /> <.button type="submit" class="w-full">Process Payment</.button>
    </.form>
  </div>
</.modal>
<!-- Waive Modal -->
<.modal
  :if={@live_action == :waive}
  id="waive-modal"
  show
  on_cancel={JS.patch(~p"/manage/circulation/fines")}
>
  <div class="space-y-4">
    <h3 class="text-lg font-medium text-gray-900">Waive Fine</h3>
    
    <div class="bg-gray-50 rounded-md p-4">
      <div class="grid grid-cols-2 gap-4 text-sm">
        <div>
          <span class="font-medium text-gray-700">Member:</span>
          <span class="ml-2">{if @fine.member, do: @fine.member.full_name, else: "Unknown"}</span>
        </div>
        
        <div>
          <span class="font-medium text-gray-700">Fine Type:</span>
          <span class="ml-2">
            {@fine.fine_type |> String.replace("_", " ") |> String.capitalize()}
          </span>
        </div>
        
        <div class="col-span-2">
          <span class="font-medium text-gray-700">Amount to Waive:</span>
          <span class="ml-2 font-semibold text-red-600">{format_idr(@fine.balance)}</span>
        </div>
      </div>
    </div>
    
    <.form for={%{}} id="waive-form" phx-submit="waive_fine" phx-value-id={@fine.id}>
      <.input
        name="reason"
        type="textarea"
        label="Reason for Waiving"
        placeholder="Explain why this fine is being waived..."
        rows="3"
        required
      /> <.button type="submit" class="w-full bg-blue-600 hover:bg-blue-700">Waive Fine</.button>
    </.form>
  </div>
</.modal>
<!-- New Fine Modal -->
<.modal
  :if={@live_action == :new}
  id="fine-modal"
  show
  on_cancel={JS.patch(~p"/manage/circulation/fines")}
>
  <div class="space-y-4">
    <h3 class="text-lg font-medium text-gray-900">New Fine</h3>
    
    <.form for={%{}} id="fine-form" phx-submit="create_fine">
      <.input
        name="member_id"
        label="Member ID"
        placeholder="Enter member ID"
        required
      />
      <.input
        name="fine_type"
        type="select"
        label="Fine Type"
        options={[
          {"Overdue", "overdue"},
          {"Lost Item", "lost_item"},
          {"Damaged Item", "damaged_item"},
          {"Processing Fee", "processing"}
        ]}
        required
      />
      <.input
        name="amount"
        type="number"
        step="1"
        label="Fine Amount (Rp)"
        placeholder="Amount will default based on member type"
        required
      />
      <div class="text-sm text-gray-500 -mt-1 mb-2">
        <strong>Note:</strong>
        For overdue fines, amount defaults to member type's daily fine rate. For other types: Lost Item (Rp 50,000), Damaged Item (Rp 25,000), Processing Fee (Rp 10,000).
      </div>
      
      <.input
        name="description"
        type="textarea"
        label="Description"
        placeholder="Describe the reason for the fine"
        rows="3"
      /> <.button type="submit" class="w-full">Create Fine</.button>
    </.form>
  </div>
</.modal>
