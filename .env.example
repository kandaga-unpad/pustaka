# Voile Basic Environment Variables
export DATABASE_URL=ecto://voile:voile@localhost/voile
export SECRET_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Auth
export VOILE_GOOGLE_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
export VOILE_GOOGLE_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
export VOILE_GOOGLE_REDIRECT_URI=http://localhost:4000/auth/google/callback

# Storage Bucket
export VOILE_S3_REGION=ap-southeast-1
export VOILE_S3_ACCESS_KEY_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
export VOILE_S3_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
export VOILE_S3_BUCKET_NAME=voile-attachments
export VOILE_S3_PUBLIC_URL=https://s3.ap-southeast-1.amazonaws.com

# Xendit Payment Gateway Configuration
# Get your credentials from https://dashboard.xendit.co
export VOILE_XENDIT_API_KEY=xnd_development_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
export VOILE_XENDIT_WEBHOOK_TOKEN=your_webhook_verification_token_here

# Production Mode (uncomment and use production keys)
# XENDIT_API_KEY=xnd_production_your_production_key_here
# XENDIT_WEBHOOK_TOKEN=your_production_webhook_token_here

# Webhook URL Configuration
# Configure this URL in Xendit Dashboard → Settings → Webhooks
# Development: http://localhost:4000/webhooks/xendit/payment
# Production: https://yourdomain.com/webhooks/xendit/payment
