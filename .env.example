# Voile Basic Environment Variables
export DATABASE_URL=ecto://voile:voile@localhost/voile
export SECRET_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Auth
export VOILE_GOOGLE_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
export VOILE_GOOGLE_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
export VOILE_GOOGLE_REDIRECT_URI=http://localhost:4000/auth/google/callback

# Storage Bucket
export VOILE_S3_REGION=ap-southeast-1
export VOILE_S3_ACCESS_KEY_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
export VOILE_S3_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
export VOILE_S3_BUCKET_NAME=voile-attachments
export VOILE_S3_PUBLIC_URL=https://s3.ap-southeast-1.amazonaws.com

# Xendit Payment Gateway Configuration
# Get your credentials from https://dashboard.xendit.co
export VOILE_XENDIT_API_KEY=xnd_development_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
export VOILE_XENDIT_WEBHOOK_TOKEN=your_webhook_verification_token_here

# Production Mode (uncomment and use production keys)
# XENDIT_API_KEY=xnd_production_your_production_key_here
# XENDIT_WEBHOOK_TOKEN=your_production_webhook_token_here

# Webhook URL Configuration
# Configure this URL in Xendit Dashboard → Settings → Webhooks
# Development: http://localhost:4000/webhooks/xendit/payment
# Production: https://yourdomain.com/webhooks/xendit/payment

# ===================================
# EMAIL CONFIGURATION
# ===================================

# Choose adapter: gmail_api, smtp, mailgun, sendgrid
export VOILE_MAILER_ADAPTER=smtp

# ===================================
# Option 1: Gmail API (RECOMMENDED - OAuth2, More Secure, No App Passwords)
# ===================================
# More secure than SMTP, uses OAuth2 instead of app passwords
# Setup: See GMAIL_API_SETUP.md for complete guide
# Quick start: Run `iex -S mix` then `Voile.Mailer.GmailAuth.interactive_setup()`

# Step 1: Get these from Google Cloud Console (https://console.cloud.google.com/apis)
export VOILE_MAILER_ADAPTER=gmail_api
export VOILE_GMAIL_CLIENT_ID=your-client-id.apps.googleusercontent.com
export VOILE_GMAIL_CLIENT_SECRET=your-client-secret
export VOILE_GMAIL_REDIRECT_URI=http://localhost:4000/auth/gmail/callback

# Step 2: Get these tokens by running the interactive setup (one-time)
export VOILE_GMAIL_ACCESS_TOKEN=ya29.a0AfB_byD...
export VOILE_GMAIL_REFRESH_TOKEN=1//0gL...

# Note: Tokens auto-refresh, setup once and forget!

# ===================================
# Option 2: SMTP (Legacy - Requires App Passwords)
# ===================================
# For Google Workspace or Self-hosted email servers
# Note: Google is deprecating app passwords, use Gmail API instead

export VOILE_SMTP_RELAY=smtp.gmail.com
export VOILE_SMTP_PORT=587
export VOILE_SMTP_USERNAME=library-system@youruniversity.edu
export VOILE_SMTP_PASSWORD=your_google_app_password_16chars
export VOILE_SMTP_SSL=false

# ===================================
# Option 3: Mailgun API
# ===================================
# export VOILE_MAILER_ADAPTER=mailgun
# export VOILE_MAILGUN_API_KEY=your_mailgun_api_key
# export VOILE_MAILGUN_DOMAIN=mg.yourdomain.edu

# ===================================
# Option 4: SendGrid API
# ===================================
# export VOILE_MAILER_ADAPTER=sendgrid
# export VOILE_SENDGRID_API_KEY=your_sendgrid_api_key

# ===================================
# LOAN REMINDER CONFIGURATION
# ===================================

# Days before due date to send reminders (comma-separated)
# Example: 3,1 means send reminder 3 days before and 1 day before
export VOILE_LOAN_REMINDER_DAYS=3,1

# How often to check for reminders (in milliseconds)
# 86400000 = 24 hours (once per day)
# 43200000 = 12 hours (twice per day)
# 3600000 = 1 hour (hourly)
export VOILE_LOAN_REMINDER_INTERVAL=86400000

# EMAIL QUEUE CONFIGURATION (Anti-Spam)
# ===================================

# Delay between sending each email (in milliseconds)
# This prevents being flagged as spam by email providers
# Recommended values:
# - 2000 (2 seconds) = 30 emails/minute, 1800/hour - RECOMMENDED for Google Workspace
# - 3000 (3 seconds) = 20 emails/minute, 1200/hour - More conservative
# - 5000 (5 seconds) = 12 emails/minute, 720/hour - Very safe
# - 1000 (1 second) = 60 emails/minute, 3600/hour - Faster but riskier
export VOILE_EMAIL_QUEUE_DELAY=2000

# Maximum number of retry attempts for failed emails
# If an email fails, it will be retried this many times before giving up
# Default: 3 retries
export VOILE_EMAIL_QUEUE_MAX_RETRIES=3
