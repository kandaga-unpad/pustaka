# Production Environment Configuration Template
# Copy this to .env.prod and fill in your production values

VOILE_POSTGRES_USER=voile
VOILE_POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
VOILE_POSTGRES_DB=voile_prod
VOILE_POSTGRES_HOSTNAME=db

# For local development (outside containers), use localhost
# export VOILE_DATABASE_URL=ecto://voile:voile@localhost/voile_dev
# For containerized development (podman-compose), use db
VOILE_DATABASE_URL=ecto://voile:CHANGE_ME@db/voile_prod
VOILE_SECRET_KEY=GENERATE_WITH_mix_phx.gen.secret

VOILE_GOOGLE_CLIENT_ID=YOUR_PRODUCTION_GOOGLE_CLIENT_ID
VOILE_GOOGLE_CLIENT_SECRET=YOUR_PRODUCTION_GOOGLE_CLIENT_SECRET
VOILE_GOOGLE_REDIRECT_URI=https://yourdomain.com/auth/google/callback

VOILE_STORAGE_ADAPTER=s3

VOILE_S3_REGION=ap-southeast-1
VOILE_S3_ACCESS_KEY_ID=YOUR_PRODUCTION_S3_KEY
VOILE_S3_SECRET_ACCESS_KEY=YOUR_PRODUCTION_S3_SECRET
VOILE_S3_BUCKET_NAME=your-production-bucket
VOILE_S3_PUBLIC_URL=https://yourdomain.com

# Xendit Payment Gateway
VOILE_XENDIT_API_KEY=YOUR_PRODUCTION_XENDIT_KEY

# Mailer Configuration
VOILE_MAILER_ADAPTER=gmail_api
VOILE_GMAIL_CLIENT_ID=YOUR_PRODUCTION_GMAIL_CLIENT_ID
VOILE_GMAIL_CLIENT_SECRET=YOUR_PRODUCTION_GMAIL_CLIENT_SECRET
VOILE_GMAIL_REDIRECT_URI=https://yourdomain.com/auth/gmail/callback
VOILE_GMAIL_ACCESS_TOKEN=YOUR_PRODUCTION_ACCESS_TOKEN
VOILE_GMAIL_REFRESH_TOKEN=YOUR_PRODUCTION_REFRESH_TOKEN

# Turnstile (Cloudflare captcha) - use test keys for testing
VOILE_TURNSTILE_SITE_KEY=1x00000000000000000000AA
VOILE_TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA