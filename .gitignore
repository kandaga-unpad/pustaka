# The directory Mix will write compiled artifacts to.
/_build/

# Python Environment
/.venv/

# If you run "mix test --cover", coverage assets end up here.
/cover/

# The directory Mix downloads your dependencies sources to.
/deps/

# Where 3rd-party dependencies like ExDoc output generated docs.
/doc/

# Ignore .fetch files in case you like to edit your project deps locally.
/.fetch

# If the VM crashes, it generates a dump, let's ignore it too.
erl_crash.dump

# Also ignore archive artifacts (built via "mix archive.build").
*.ez

# Temporary files, for example, from tests.
/tmp/

# Ignore package tarball (built via "mix hex.build").
voile-*.tar

# Ignore assets that are produced by build tools.
/priv/static/assets/

# Ignore digested assets cache.
/priv/static/cache_manifest.json

# Ignore Swagger JSON files
/priv/static/swagger.json

# In case you use Node.js/npm, you want to ignore these.
npm-debug.log
/assets/node_modules/

# Environment Variable
.env
.env.*
!.env.*.example
*.bat

# Private Assets
/priv/static/uploads/asset_vault/*
/priv/static/uploads/thumbnail/*
/priv/static/uploads/thumbnails/*
/priv/static/uploads/files/*
/priv/static/uploads/glams/*
/priv/static/uploads/old_thumbnail/*
/priv/static/uploads/media/*
/priv/static/uploads/attachments/*
/priv/static/uploads/user_image/*
/priv/static/uploads/user_media/*
/priv/static/uploads/app_logo/*

# Except Thumbnail sample
!/priv/static/uploads/thumbnail/upload.txt
!/priv/static/uploads/media/upload.txt
!/priv/static/uploads/attachments/upload.txt

# Scripts Source
/scripts/*.csv
/scripts/csv_data.zip

# CSV Data - ignore numbered files but keep samples
/scripts/csv_data/**/*_[0-9]*.csv
/scripts/csv_data/**/*_master*.csv
/scripts/csv_data/**/temp*.csv
/scripts/csv_data/**/test*.csv
*.csv

# Language Server
.elixir_ls/
.expert

# MKDocs Generated Site
/site/