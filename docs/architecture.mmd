flowchart LR
  %% Client
  subgraph Client
    direction TB
    A[User Browser / Mobile App] -->|"HTTP / WebSocket LiveView"| Endpoint[Phoenix Endpoint]
    Atrium[Atrium Patron Portal] -->|"HTTP / WS"| Endpoint
  end

  %% Phoenix App
  subgraph WebLayer[Phoenix App]
    direction TB
    Endpoint --> Router[Router & Pipelines]
    Router --> LiveView[LiveView / LiveComponents]
    Router --> Controllers[Controllers / API Controllers]
    LiveView --> UI[Core Components / Forms / Streams]
    Controllers --> Contexts[Contexts business logic]
    Contexts --> Repo[(Ecto.Repo / Postgres)]
    Contexts --> AttachmentMgr[Attachment Manager / Presigner]
    Contexts --> Auth["Auth & Session / RBAC (phx.gen.auth)"]
    LiveView -->|"pubsub events"| PubSub[(Phoenix.PubSub)]
  end

  %% Storage & Attachment flow
  subgraph Storage
    direction TB
    AttachmentMgr --> Presigner[Presigner Service]
    Presigner --> ObjectStorage[(S3-compatible Object Storage)]
    ObjectStorage --> AttachmentWorker["Attachment Processor (background job)"]
    AttachmentWorker --> Repo
  end

  %% Background processing
  subgraph Background
    direction TB
    Queue[Oban / Background Queue] --> AttachmentWorker
    Queue --> FineBot[Fine Bot / Scheduler]
    FineBot --> Repo
    FineBot --> Notifier["Notification System (Email/SMS)"]
    Notifier --> ExternalMail[(SMTP / Gmail API)]
  end

  %% Infrastructure & integrations (project-specific)
  subgraph Infra
    direction TB
    Repo --> Postgres[(Postgres DB)]
    Assets[_build/esbuild & tailwind] --> Static[Static Assets Served]
    Container["Podman / Containerfile & Containerfile.dev"] --> Image[Podman Image]
    Scripts["./scripts/deploy.sh, ./scripts/manage.sh, mix precommit"] --> Container
    ExternalAPI["Third-party APIs (Payment, Xendit, Gmail API, etc.)"]
  end

  %% cross connections
  Endpoint -->|"on_mount/fetch"| Auth
  Contexts -->|"enqueue jobs"| Queue
  Contexts -->|"http"| Req[Req HTTP client]
  Notifier -->|"send"| ExternalMail
  Image -->|"deploy via podman"| ImageDeployed["Deployed Instance (host)"]

  %% styling
  classDef client fill:#fef3c7,stroke:#f59e0b
  classDef web fill:#eef2ff,stroke:#4338ca
  classDef storage fill:#ecfeff,stroke:#0891b2
  classDef infra fill:#f0f9ff,stroke:#0ea5a4

  class A,Atrium client
  class Endpoint,Router,LiveView,Controllers,UI,Contexts,Auth,PubSub web
  class Presigner,ObjectStorage,AttachmentWorker,AttachmentMgr storage
  class Repo,Postgres,Assets,Container,Image,Scripts,ExternalAPI,Req infra

  %% short legend
  subgraph Legend
    direction LR
    L1[HTTP / WS flows] --> L2[Background / Async flows]
  end
